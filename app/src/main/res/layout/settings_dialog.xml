<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Material3.CardView.Elevated"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/settings"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />

            <!-- Sound Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Audio"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorSecondary" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Master Volume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/master_volume"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/seekSound"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="10"
                    android:stepSize="1"
                    android:value="5" />

                <TextView
                    android:id="@+id/txtSoundValue"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="5"
                    android:gravity="center" />
            </LinearLayout>

            <!-- BGM Volume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/bgm_volume"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/seekBgm"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="10"
                    android:stepSize="1"
                    android:value="7" />

                <TextView
                    android:id="@+id/txtBgmValue"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="7"
                    android:gravity="center" />
            </LinearLayout>

            <!-- SFX Volume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sfx_volume"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/seekSfx"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="10"
                    android:stepSize="1"
                    android:value="7" />

                <TextView
                    android:id="@+id/txtSfxValue"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="7"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="BGM Selection"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorSecondary" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Main BGM"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupMainBgm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMainBgm1"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Track 1" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMainBgm2"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Track 2" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMainBgm3"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Track 3" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Game BGM"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupGameBgm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameBgm1"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Track 1" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameBgm2"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Track 2" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Graphics Group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Graphics"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorSecondary" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/fps"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupFps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:singleSelection="true"
                app:checkedButton="@+id/radioFps120">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioFps60"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/fps_60" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioFps120"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/fps_120" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioFps180"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/fps_180" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchVibration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:checked="true"
                android:text="@string/vibration"
                android:textAppearance="?attr/textAppearanceBodyLarge" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClose"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/close"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>