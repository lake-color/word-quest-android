<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Header & Progress -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        app:icon="@android:drawable/ic_menu_revert"
        app:iconTint="?attr/colorPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtStudyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_stage_number"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressStudy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:trackCornerRadius="4dp"
        app:trackThickness="8dp" />

    <TextView
        android:id="@+id/txtProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0/20"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOutline"
        app:layout_constraintEnd_toEndOf="@id/progressStudy"
        app:layout_constraintTop_toBottomOf="@id/progressStudy" />

    <!-- Word Card (English) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWord"
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="24dp"
        app:layout_constraintDimensionRatio="4:3"
        app:layout_constraintTop_toBottomOf="@id/txtProgress"
        app:layout_constraintBottom_toTopOf="@id/cardMean">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:ignore="MissingDefaultResource" />

        <TextView
            android:id="@+id/txtWord"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="English Word"
            android:textAppearance="?attr/textAppearanceHeadlineLarge"
            android:textColor="?attr/colorPrimary"
            android:textSize="44sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Meaning Card (Korean) - Hidden by default -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMean"
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="24dp"
        app:layout_constraintDimensionRatio="4:1.8"
        app:layout_constraintTop_toBottomOf="@id/cardWord">

        <TextView
            android:id="@+id/txtMean"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/click_to_see_meaning"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorSecondary"
            android:alpha="0.8" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Star Button with Animation -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStar"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        app:icon="@android:drawable/btn_star_big_off"
        app:iconSize="40dp"
        app:iconTint="?attr/colorTertiary"
        app:layout_constraintTop_toBottomOf="@id/cardMean"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Navigation Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPrev"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="40dp"
        android:minWidth="100dp"
        android:text="@string/prev"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        style="@style/Widget.Material3.Button"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:minWidth="100dp"
        android:text="@string/next"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
