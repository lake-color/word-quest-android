<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- HUD (Score & HP) -->
    <LinearLayout
        android:id="@+id/layoutHUD"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Score: 0"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtHP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HP: 3"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorTertiary"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Question Word -->
    <TextView
        android:id="@+id/txtCurrentWord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="QUESTION"
        android:textAppearance="?attr/textAppearanceHeadlineLarge"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHUD" />

    <!-- Track Area -->
    <View
        android:id="@+id/viewTrack"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="100dp"
        android:background="?attr/colorSurfaceVariant"
        android:alpha="0.3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtCurrentWord" />

    <!-- Left Gate -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/gateLeft"
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="90dp"
        android:layout_height="120dp"
        app:cardBackgroundColor="?attr/colorSecondaryContainer"
        app:cardCornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="@id/viewTrack"
        app:layout_constraintEnd_toStartOf="@id/viewTrack"
        app:layout_constraintTop_toTopOf="@id/viewTrack"
        app:layout_constraintVertical_bias="0.3">

        <TextView
            android:id="@+id/txtGateLeft"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="8dp"
            android:text="Choice A"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Right Gate -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/gateRight"
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="90dp"
        android:layout_height="120dp"
        app:cardBackgroundColor="?attr/colorTertiaryContainer"
        app:cardCornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="@id/viewTrack"
        app:layout_constraintStart_toEndOf="@id/viewTrack"
        app:layout_constraintTop_toTopOf="@id/viewTrack"
        app:layout_constraintVertical_bias="0.3">

        <TextView
            android:id="@+id/txtGateRight"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="8dp"
            android:text="Choice B"
            android:textColor="?attr/colorOnTertiaryContainer"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Player Character (Simulated with an Icon) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/playerCharacter"
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:cardCornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="@id/viewTrack"
        app:layout_constraintEnd_toEndOf="@id/viewTrack"
        app:layout_constraintStart_toStartOf="@id/viewTrack">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="?attr/colorOnPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Control Areas (Invisible click zones) -->
    <View
        android:id="@+id/clickLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/viewTrack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/clickRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/viewTrack"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>