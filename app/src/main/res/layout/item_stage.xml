<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <!-- Connecting Lines (Zigzag logic in adapter) -->
    <View
        android:id="@+id/lineNext"
        android:layout_width="4dp"
        android:layout_height="120dp"
        android:background="?attr/colorOutlineVariant"
        android:alpha="0.2"
        android:rotation="0"
        app:layout_constraintTop_toBottomOf="@id/cardStage"
        app:layout_constraintStart_toStartOf="@id/cardStage"
        app:layout_constraintEnd_toEndOf="@id/cardStage" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStage"
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:cardCornerRadius="55dp"
        app:cardElevation="6dp"
        app:strokeWidth="4dp"
        app:strokeColor="?attr/colorPrimaryContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_label"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOutline" />

            <TextView
                android:id="@+id/txtStageNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
