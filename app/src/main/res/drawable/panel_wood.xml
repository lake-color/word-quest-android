<!-- res/drawable/panel_wood.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 배경색 -->
    <gradient
        android:startColor="#E9D1AC"
        android:centerColor="#E0C08E"
        android:endColor="#D4A76A"
        android:angle="270" />

    <!-- 테두리 -->
    <stroke
        android:width="4dp"
        android:color="#5D3A1A"/>

    <!-- 모서리 -->
    <corners android:radius="25dp"/>
</shape>