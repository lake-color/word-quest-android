<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. 버튼 그림자 -->
    <item>
        <shape>
            <solid android:color="#5A341A" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- 2. 버튼 몸체 -->
    <item android:bottom="4dp">
        <shape>
            <gradient
                android:startColor="#DBC296"
                android:centerColor="#CFAE7A"
                android:endColor="#A38355"
                android:angle="270" />

            <stroke
                android:width="2dp"
                android:color="#5A341A" />

            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>