<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 전체 배경 그라데이션 (멀리 갈수록 어두워짐) -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#F4E0DB"
                android:endColor="#D7CCC8"
                android:type="linear" />
        </shape>
    </item>
    <!-- 도로 가이드라인 (V자 형태의 원근감 라인) -->
    <item>
        <rotate
            android:fromDegrees="-15"
            android:pivotX="50%"
            android:pivotY="0%">
            <shape>
                <size android:width="2dp" />
                <solid android:color="#405D4037" />
            </shape>
        </rotate>
    </item>
    <item>
        <rotate
            android:fromDegrees="15"
            android:pivotX="50%"
            android:pivotY="0%">
            <shape>
                <size android:width="2dp" />
                <solid android:color="#405D4037" />
            </shape>
        </rotate>
    </item>
</layer-list>