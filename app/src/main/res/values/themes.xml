<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FinalProjectApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Colors -->
        <item name="colorPrimary">@color/wood_brown</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/light_wood</item>
        <item name="colorOnPrimaryContainer">@color/dark_brown</item>

        <item name="colorSecondary">@color/leaf_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/light_green</item>
        <item name="colorOnSecondaryContainer">@color/dark_green</item>

        <item name="colorTertiary">@color/deep_orange</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/light_orange</item>
        <item name="colorOnTertiaryContainer">@color/dark_orange</item>

        <item name="android:windowBackground">@color/cream_background</item>
        <item name="colorSurface">@color/soft_cream</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="colorSurfaceVariant">@color/light_beige</item>
        <item name="colorOnSurfaceVariant">@color/secondary_text</item>
        <item name="colorOutline">@color/outline</item>

        <!-- Status Bar & Navigation Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.FinalProjectApp" parent="Base.Theme.FinalProjectApp" />

    <!-- Modern Card Style -->
    <style name="Widget.WordQuest.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/soft_cream</item>
    </style>

    <!-- Modern Wood-Themed Button Style -->
    <style name="Widget.WordQuest.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>