<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FinalProjectApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Colors (Navy & Cool Tones) -->
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/navy_light</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/cool_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/cool_gray</item>
        <item name="colorOnSecondaryContainer">@color/navy_dark</item>

        <item name="colorTertiary">@color/star_yellow</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorTertiaryContainer">@color/star_yellow</item>
        <item name="colorOnTertiaryContainer">@color/navy_dark</item>

        <item name="android:windowBackground">@color/cool_background</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/navy_dark</item>
        <item name="colorSurfaceVariant">@color/cool_gray</item>
        <item name="colorOnSurfaceVariant">@color/navy_primary</item>
        <item name="colorOutline">@color/star_border</item>

        <!-- Status Bar & Navigation Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.FinalProjectApp" parent="Base.Theme.FinalProjectApp" />

    <!-- Modern Card Style -->
    <style name="Widget.WordQuest.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Modern Button Style -->
    <style name="Widget.WordQuest.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>
